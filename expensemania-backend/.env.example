APP_ENV=development
PORT=8080

MONGODB_URI=
MONGODB_DB=expensemania

JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

